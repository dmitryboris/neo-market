ENV=test
# B2B Database settings
B2B_DB_NAME=b2b
B2B_DB_USER=postgres
B2B_DB_PASSWORD=password
B2B_DB_PORT=5432
B2B_DB_HOST=b2b_db

# B2C Database settings
B2C_DB_NAME=b2c
B2C_DB_USER=postgres
B2C_DB_PASSWORD=password
B2C_DB_PORT=5433
